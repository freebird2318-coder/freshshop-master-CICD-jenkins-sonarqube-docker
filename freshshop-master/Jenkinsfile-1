pipeline {

    agent any

    environment {
        REMOTE_HOST = "54.145.217.16"
        REMOTE_USER = "ubuntu"

        IMAGE_NAME = "mywebsite2"
        CONTAINER_NAME = "freshshop-master2"

        SONAR_SCANNER = tool 'SonarScanner'
    }

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'main',
                    credentialsId: 'freebird2318-coder',
                    url: 'https://github.com/freebird2318-coder/freshshop-master-CICD-jenkins-sonarqube-docker.git'
            }
        }

        stage('SonarQube Analysis') {
            steps {

                withSonarQubeEnv('SonarQube') {

                    withCredentials([
                        string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')
                    ]) {

                        sh """
                        ${SONAR_SCANNER}/bin/sonar-scanner \
                        -Dsonar.projectKey=freshshop-master \
                        -Dsonar.projectName=freshshop-master \
                        -Dsonar.sources=. \
                        -Dsonar.host.url=\$SONAR_HOST_URL \
                        -Dsonar.token=\$SONAR_TOKEN
                        """

                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Deploy To Docker Server') {

            steps {

                sshagent(credentials: ['docker-creds']) {

                    sh """

                    ssh -o StrictHostKeyChecking=no ${REMOTE_USER}@${REMOTE_HOST} '
                    mkdir -p ~/website
                    '

                    scp -o StrictHostKeyChecking=no -r ./* ${REMOTE_USER}@${REMOTE_HOST}:~/website/

                    ssh -o StrictHostKeyChecking=no ${REMOTE_USER}@${REMOTE_HOST} '

                    cd ~/website

                    docker rm -f ${CONTAINER_NAME} || true

                    docker rmi ${IMAGE_NAME} || true

                    docker build -t ${IMAGE_NAME} .

                    docker run -d \
                        --name ${CONTAINER_NAME} \
                        -p 8086:80 \
                        ${IMAGE_NAME}

                    docker ps

                    '

                    """
                }
            }
        }
    }

    post {

        success {
            echo 'Build, SonarQube scan and Docker deployment completed successfully.'
        }

        failure {
            echo 'Pipeline failed.'
        }

        always {
            cleanWs()
        }
    }
}
