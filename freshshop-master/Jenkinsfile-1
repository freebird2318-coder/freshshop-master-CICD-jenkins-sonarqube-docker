pipeline {

    agent any

    tools {
        sonarQube 'sonarqube-scanner'
    }

    environment {
        REMOTE_HOST = "54.145.217.16"
        REMOTE_USER = "ubuntu"
        IMAGE_NAME = "mywebsite1"
        CONTAINER_NAME = "freshshop-master1"
    }

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'main',
                    credentialsId: 'freebird2318-coder',
                    url: 'https://github.com/freebird2318-coder/freshshop-master-CICD-jenkins-sonarqube-docker.git'
            }
        }


        stage('SonarQube Analysis') {

            steps {

                withSonarQubeEnv('SonarQube') {

                    withCredentials([
                        string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')
                    ]) {

                        sh '''
                        sonar-scanner \
                        -Dsonar.projectKey=freshshop-master \
                        -Dsonar.projectName=freshshop-master \
                        -Dsonar.sources=freshshop-master \
                        -Dsonar.host.url=$SONAR_HOST_URL \
                        -Dsonar.token=$SONAR_TOKEN
                        '''

                    }

                }

            }

        }


        stage('Quality Gate') {

            steps {

                timeout(time: 5, unit: 'MINUTES') {

                    waitForQualityGate abortPipeline: true

                }

            }

        }


        stage('Deploy To Docker Server') {

            steps {

                sshagent(['docker-creds']) {

                    sh '''

                    ssh -o StrictHostKeyChecking=no ubuntu@54.145.217.16 "
                    mkdir -p ~/website
                    "


                    scp -o StrictHostKeyChecking=no -r \
                    freshshop-master \
                    ubuntu@54.145.217.16:~/website/


                    ssh -o StrictHostKeyChecking=no ubuntu@54.145.217.16 "

                    cd ~/website/freshshop-master


                    docker rm -f freshshop-master1 || true


                    docker rmi mywebsite1 || true


                    docker build -t mywebsite2 .


                    docker run -d \
                    -p 8086:80 \
                    --name fruitkha-website2 \
                    mywebsite


                    docker ps

                    "

                    '''

                }

            }

        }

    }


    post {

        success {
            echo "Build, SonarQube scan and Docker deployment completed successfully."
        }

        failure {
            echo "Pipeline failed."
        }

    }

}

