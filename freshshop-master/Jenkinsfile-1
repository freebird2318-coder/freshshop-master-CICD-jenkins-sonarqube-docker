pipeline {
    agent any

    environment {
        REMOTE_HOST = "54.145.217.16"
        REMOTE_USER = "ubuntu"

        IMAGE_NAME = "mywebsite"
        CONTAINER_NAME = "freshshop-master1"

        APP_PORT = "8086"

        SCANNER_HOME = tool 'sonarqube-scanner'
    }

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'main',
                    credentialsId: 'freebird2318-coder',
                    url: 'https://github.com/freebird2318-coder/freshshop-master-CICD-jenkins-sonarqube-docker.git'
            }
        }

        stage('Verify Workspace') {
            steps {
                sh '''
                echo "Current Directory:"
                pwd

                echo "Workspace Files:"
                ls -la
                '''
            }
        }

        stage('SonarQube Analysis') {
            steps {

                withSonarQubeEnv('SonarQube') {

                    withCredentials([
                        string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')
                    ]) {

                        sh """
                        ${SCANNER_HOME}/bin/sonar-scanner \
                        -Dsonar.projectKey=freshshop-master \
                        -Dsonar.projectName=freshshop-master \
                        -Dsonar.sources=. \
                        -Dsonar.host.url=\$SONAR_HOST_URL \
                        -Dsonar.token=\$SONAR_TOKEN
                        """

                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Deploy Application') {

            steps {

                sshagent(credentials: ['docker-creds']) {

                    sh """
                    ssh -o StrictHostKeyChecking=no ${REMOTE_USER}@${REMOTE_HOST} '
                        mkdir -p ~/website
                    '

                    rsync -av --delete \
                        --exclude=".git" \
                        --exclude=".scannerwork" \
                        ./ ${REMOTE_USER}@${REMOTE_HOST}:~/website/

                    ssh -o StrictHostKeyChecking=no ${REMOTE_USER}@${REMOTE_HOST} '

                        cd ~/website

                        docker stop ${CONTAINER_NAME} || true

                        docker rm ${CONTAINER_NAME} || true

                        docker rmi ${IMAGE_NAME} || true

                        docker build -t ${IMAGE_NAME} .

                        docker run -d \
                            --name ${CONTAINER_NAME} \
                            -p ${APP_PORT}:80 \
                            ${IMAGE_NAME}

                        docker ps

                    '
                    """
                }
            }
        }
    }

    post {

        success {
            echo 'Pipeline executed successfully.'
        }

        failure {
            echo 'Pipeline execution failed.'
        }
    }
}
