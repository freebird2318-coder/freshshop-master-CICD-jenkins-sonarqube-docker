pipeline {

    agent any

    environment {

        SONAR_PROJECT_KEY = "freshshop-master"

        DOCKER_SERVER = "ubuntu@54.145.217.16"

        DOCKER_PATH = "/home/ubuntu/website"

        IMAGE_NAME = "mywebsite"

        CONTAINER_NAME = "freshshop-master1"

        APP_PORT = "8086"

    }


    stages {


        stage('Checkout Code') {

            steps {

                echo "Getting code from GitHub"


                git(
                    url: 'https://github.com/freebird2318-coder/freshshop-master-CICD-jenkins-sonarqube-docker.git',
                    branch: 'main',
                    credentialsId: 'freebird2318-coder'
                )

            }

        }



        stage('Verify Workspace') {

            steps {

                sh '''

                echo "Current Directory"

                pwd


                echo "Workspace Files"

                ls -la

                '''

            }

        }




        stage('SonarQube Analysis') {

            steps {

                echo "Running SonarQube Scan"


                withSonarQubeEnv('sonar-srv') {


                    withCredentials([

                        string(
                            credentialsId: 'sonarqube-token',
                            variable: 'SONAR_TOKEN'
                        )

                    ]) {


                        script {

                            def scannerHome = tool 'sonar-scanner'


                            sh """

                            ${scannerHome}/bin/sonar-scanner \\

                            -Dsonar.projectKey=${SONAR_PROJECT_KEY} \\

                            -Dsonar.projectName=${SONAR_PROJECT_KEY} \\

                            -Dsonar.sources=. \\

                            -Dsonar.host.url=\$SONAR_HOST_URL \\

                            -Dsonar.token=\$SONAR_TOKEN

                            """

                        }

                    }

                }

            }

        }




        stage('Quality Gate') {


            steps {


                echo "Checking SonarQube Quality Gate"


                timeout(time: 5, unit: 'MINUTES') {


                    waitForQualityGate abortPipeline: true


                }


            }


        }




        stage('Copy Code To Docker Server') {


            steps {


                echo "Copying Code To Docker Server"



                sshagent(['docker-creds']) {


                    sh """


                    ssh -o StrictHostKeyChecking=no ${DOCKER_SERVER} '

                    rm -rf ${DOCKER_PATH}

                    mkdir -p ${DOCKER_PATH}

                    '



                    rsync -av --delete \\

                    --exclude=".git" \\

                    --exclude=".scannerwork" \\

                    ./ \\

                    ${DOCKER_SERVER}:${DOCKER_PATH}/



                    """


                }


            }


        }





        stage('Docker Build') {


            steps {


                echo "Building Docker Image"



                sshagent(['docker-creds']) {


                    sh """


                    ssh -o StrictHostKeyChecking=no ${DOCKER_SERVER} '


                    cd ${DOCKER_PATH}


                    docker build -t ${IMAGE_NAME}:latest .


                    '


                    """


                }


            }


        }




        stage('Deploy Container') {


            steps {


                echo "Deploying Application"



                sshagent(['docker-creds']) {


                    sh """


                    ssh -o StrictHostKeyChecking=no ${DOCKER_SERVER} '



                    docker stop ${CONTAINER_NAME} || true


                    docker rm ${CONTAINER_NAME} || true



                    docker run -d \\

                    --name ${CONTAINER_NAME} \\

                    -p ${APP_PORT}:80 \\

                    ${IMAGE_NAME}:latest



                    docker ps



                    '



                    """


                }


            }


        }


    }



    post {


        success {

            echo "Deployment Successful"

        }


        failure {

            echo "Deployment Failed"

        }


    }


}
